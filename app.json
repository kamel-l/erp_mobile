{
  "expo": {
    "name": "ERP Mobile",
    "slug": "erp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.kamelat.erpmobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-build-properties",
      "expo-secure-store",
      "expo-sharing"
    ]
  }
}
