{
  "expo": {
    "name": "ERP Mobile",
    "slug": "erp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.kmeldz.erpmobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-build-properties",
      "expo-secure-store",
      "expo-sharing",
      "expo-sqlite",
      "expo-barcode-scanner",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "aedb280c-260a-494f-9b9b-d9e252a8147a"
      }
    }
  }
}
